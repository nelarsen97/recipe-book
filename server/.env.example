# Copy to .env and fill in. See README.md for how to get each value.

# Shared secret the app must send in the X-API-Key header.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Google account that owns the Keep shopping list.
GOOGLE_EMAIL=

# Obtained with: python get_master_token.py   (treat like a password!)
GOOGLE_MASTER_TOKEN=

# ID of the Keep checklist to append to.
# Obtained with: python get_master_token.py --list-notes
KEEP_NOTE_ID=

# Optional overrides (defaults shown):
# RECIPES_DB=data/recipes.db
# KEEP_STATE_FILE=data/keep_state.json
